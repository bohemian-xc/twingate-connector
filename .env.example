## Example environment variables for twingate-connector
# Copy this file to `.env` and fill in values before running compose

# Container/hostname
TG_LABEL_HOSTNAME=twingate-connector

# Twingate configuration (fill with your real values)
TG_NETWORK=your-twingate-network
TG_ACCESS_TOKEN=replace-with-access-token
TG_REFRESH_TOKEN=replace-with-refresh-token

# External Docker networks (these are referenced in docker-twingate-vlan.yml)
# `gw_net` is expected to be an external network name
GW_NAME=gw_net_name_here
# IP address to assign the connector on the `gw_net` network (optional)
GW_IPADDRESS=192.168.10.60

# `br_net` is another external network used by the service
BR_NAME=br_net_name_here

# Notes:
# - The compose file expects external networks named by GW_NAME and BR_NAME.
# - Create or ensure those networks exist before running `docker compose up`.

