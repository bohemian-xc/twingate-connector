## Example environment variables for twingate-connector
# Copy this file to `.env` and fill in values before running compose

# Container/hostname
TG_LABEL_HOSTNAME=twingate-connector

# VLAN / macvlan network settings
# Parent should be the VLAN sub-interface on the Pi (e.g. eth0.10)
VLAN10_PARENT=eth0.10
# Subnet in CIDR form used for the macvlan network
VLAN10_SUBNET=192.168.10.0/24
# Gateway for the macvlan network
VLAN10_GATEWAY=192.168.10.1
# Optional: specific IP to assign to the connector container
VLAN10_IPADDRESS=192.168.10.60

# Twingate configuration (fill with your real values)
TG_NETWORK=your-twingate-network
TG_ACCESS_TOKEN=replace-with-access-token
TG_REFRESH_TOKEN=replace-with-refresh-token
